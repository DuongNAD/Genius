# Genius (Antigravity 2.0) — environment template.
# Copy to `.env` and fill in. NEVER commit the real `.env`.
# Agents must not read this file directly; values are injected via config.

# --- LLM provider API keys (optional: local CLIs can self-authenticate) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Grok is an OPT-IN backend only (no default provider chain uses it); the key
# is honored when you enable it via GENIUS_PROVIDER_<ROLE>=grok,...
GROK_API_KEY=
# xAI also accepts XAI_API_KEY as an alias for the Grok key.
XAI_API_KEY=
# Grok CLI model, passed as `-m` in headless mode. Empty by default -> the Grok
# CLI uses its own configured default model. Grok model ids are install-specific
# (`grok models` lists them); pin one explicitly, e.g.:
# GENIUS_GROK_MODEL=grok-composer-2.5-fast

# --- Provider base URLs (override only for proxies / self-hosted gateways) ---
OPENAI_BASE_URL=
ANTHROPIC_BASE_URL=
GROK_BASE_URL=

# --- Inter-service auth (HMAC-SHA256 + JWT between orchestrator and skills) ---
# Must match on both the orchestrator and every skill server. Required in
# production; tests seed their own value.
SKILL_API_KEY=

# --- Git integration (used by ag_core/utils/git.py for push/auth) ---
GIT_USERNAME=
GIT_TOKEN=

# --- Optional paths / discovery ---
ANTIGRAVITY_BIN_PATH=
GENIUS_HUB_URL=
GENIUS_SERVICE_REGISTRY=
GENIUS_DB_PATH=
GENIUS_MEMORY_DB_PATH=
GENIUS_CHROMA_DIR=
CHROMA_PERSIST_DIR=

# --- MCP HTTP server (mcp_server.py, `python mcp_server.py` without stdio) ---
# Bind host/port. Default host is 127.0.0.1 so the tool endpoint isn't
# reachable off-box. Only set 0.0.0.0 together with GENIUS_MCP_TOKEN.
GENIUS_MCP_HOST=
GENIUS_MCP_PORT=
# Bearer token required on POST /tools/call. Blank = no auth (safe only on the
# default localhost bind). Set this whenever the server is exposed.
GENIUS_MCP_TOKEN=
# Root dir for per-job orchestrate workspaces (default: ./.genius_jobs/<job_id>).
# Each MCP orchestrate job gets its own subdir so concurrent jobs don't clobber
# each other's artifacts.
GENIUS_JOBS_DIR=

# --- Web dashboard (dashboard.py) ---
# Bind host/port. Default host is 127.0.0.1 so the prompt/result/error history
# isn't reachable off-box. Only set 0.0.0.0 together with GENIUS_DASHBOARD_TOKEN.
GENIUS_DASHBOARD_HOST=
GENIUS_DASHBOARD_PORT=
# Token required on the data endpoints (/api/*, /ws) when set. Blank = no auth
# (safe only on the default localhost bind). Open /?token=<token> in the browser.
GENIUS_DASHBOARD_TOKEN=

# --- Auth token lifetime ---
# Max allowed (exp - now) in seconds for an authenticating JWT at the hub /
# skill-server boundary. Rejects absurdly long-lived tokens. Default 3600;
# production tokens are minted with a 300s lifetime.
GENIUS_JWT_MAX_LIFETIME=

# --- Distributed hub hardening ---
# Opt-in anti-replay on the authenticated HTTP path: require a fresh
# X-Timestamp + unseen X-Nonce (both are always emitted by clients). Off by
# default. NOTE: the HTTP path still transmits the raw secret in X-API-Key, so
# pair this with TLS — it is not a full fix on its own.
GENIUS_HUB_REPLAY_PROTECTION=
# Freshness window (seconds) for the above. Default 300.
GENIUS_HUB_REPLAY_WINDOW=
# Second credential for the hub ADMIN endpoints (/update_config, /tasks,
# /write_workspace_file): when set, those additionally require it in an
# X-Admin-Key header, so the shared SKILL_API_KEY stays a worker/client
# credential. Strongly recommended whenever the hub leaves loopback.
GENIUS_HUB_ADMIN_KEY=
# /write_workspace_file is DISABLED outside pytest unless this is 1 (no
# production caller uses it). Pin the writable root with the second variable
# (default: the hub's working directory).
GENIUS_HUB_WORKSPACE_WRITE=
GENIUS_HUB_WORKSPACE_ROOT=
# Workers dial wss:// instead of ws:// (hub behind a TLS-terminating proxy).
GENIUS_HUB_TLS=
# Legacy compat only: put the worker JWT back in the WS query string for hubs
# that predate Authorization-header auth. Default off (header auth).
GENIUS_WS_TOKEN_QUERY=

# --- Production security profile (fail-closed) ---
# Opt-in. When 1, serve.py REFUSES to start unless the fail-open conveniences
# are explicitly overridden: GENIUS_CONFIG_PATH must be set (no cwd config
# walk), and running the hub (--distributed) additionally requires
# GENIUS_HUB_ADMIN_KEY plus an explicit transport choice (GENIUS_HUB_TLS=1 or
# GENIUS_ALLOW_PLAINTEXT=1). Off by default so local / trusted-LAN runs are
# unchanged.
GENIUS_SECURE_DEFAULTS=
# Knowingly accept the hub's plaintext HTTP/ws transport under the secure
# profile (use only on a trusted LAN/VPN; prefer GENIUS_HUB_TLS with a proxy).
GENIUS_ALLOW_PLAINTEXT=

# --- Explicit trusted config paths ---
# Pin exactly WHICH config.yaml / .env ag_core.config loads and disable the
# cwd-upward walk (running Genius inside an untrusted repo must not let that
# repo's files reconfigure providers/services). Blank = legacy walk.
GENIUS_CONFIG_PATH=
GENIUS_ENV_FILE=

# --- Skill server task persistence ---
# Opt-in durable task/idempotency state (SQLite journal, restored on restart:
# pollers see a terminal status instead of a 404 after a crash, and idempotent
# retries never rerun the agent). Default off = in-memory only.
GENIUS_TASK_PERSIST=

# --- Skill server limits ---
# Max bytes a skill response may be before the checksum middleware refuses to
# buffer it (guards against unbounded memory use). Default 26214400 (25 MiB).
GENIUS_MAX_RESPONSE_BYTES=

# --- Behaviour toggles (0/1) ---
# Generic bind-address fallback for every server this process starts, used
# when the matching per-service variable is unset. Every bare-metal service
# defaults to 127.0.0.1. Set the relevant per-service variable to 0.0.0.0 only
# when LAN/container reachability is required; authentication remains mandatory.
GENIUS_BIND_HOST=
# Per-service overrides for the agent skill servers and the central hub
# (dashboard/MCP have theirs above). Specific beats GENIUS_BIND_HOST.
GENIUS_SKILL_HOST=
GENIUS_HUB_HOST=
# TTL (seconds) for the load_config() cache on per-request hot paths.
# Default 5; 0 disables. Always disabled under pytest.
GENIUS_CONFIG_CACHE_TTL=
# Token budget for the graph-aware workspace context sent to each agent call
# (aider-repo-map-style ranking; seeds = files the task names). Default
# 32000; 0 disables trimming. Workspaces already under the budget pass
# through unchanged.
GENIUS_CONTEXT_TOKEN_BUDGET=
# Re-enable the module-level API response cache (off under pytest).
ENABLE_GENIUS_CACHE=
# Max entries in the (LRU-bounded) API response cache. Default 256.
GENIUS_CACHE_MAXSIZE=
# Toggle the TokenBucket rate limiter.
ENABLE_RATE_LIMITER=
# Codex CLI sandbox policy: read-only (default; Codex can think but not run
# commands or write files), workspace-write, or danger (the old
# --dangerously-bypass-approvals-and-sandbox behaviour). Legacy 1/true/yes
# values map to read-only.
GENIUS_CODEX_SANDBOX=

# --- Antigravity 2.0 (agy CLI, Gemini backend "agy") ---
# Explicit path to the agy executable. Default resolution: PATH, then
# %LOCALAPPDATA%\agy\bin\agy.exe. Auth is shared with the Antigravity IDE
# login (no API key needed).
GENIUS_AGY_PATH=
# agy runs with --sandbox (terminal restrictions) by default because print
# mode requires --dangerously-skip-permissions. Set 0 to drop --sandbox.
GENIUS_AGY_SANDBOX=

# --- Provider fallback chains (see ag_core/provider_factory.py) ---
# Fallback chains are the DEFAULT - no env var needed. Default chains:
# research (role grok): agy -> claude -> codex; architect (role claude):
# claude -> agy -> codex; all other roles: codex -> claude -> agy. A backend
# failing at runtime falls through to the next one. The grok backend is
# opt-in only and appears in no default chain.
# GENIUS_PROVIDER_FALLBACK is DEPRECATED: chains are the default now, so this
# knob is accepted but ignored (truthy or falsy makes no difference).
# GENIUS_PROVIDER_FALLBACK=
# Explicit per-role chain override (comma-separated backends: grok, agy,
# claude, codex). Example: bring the grok backend back as the research
# primary, with agy as the runtime fallback.
# GENIUS_PROVIDER_GROK=grok,agy
# Per-role reasoning effort for the claude backend when it serves that role —
# including as a runtime FALLBACK backend. E.g. the security role's chain
# "codex,claude,agy" falls back to claude (opus) when the codex CLI fails or
# is rate-limited; set the fallback's effort explicitly:
# GENIUS_CLAUDE_EFFORT_SECURITY=max
