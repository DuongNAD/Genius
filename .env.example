# Genius (Antigravity 2.0) — environment template.
# Copy to `.env` and fill in. NEVER commit the real `.env`.
# Agents must not read this file directly; values are injected via config.

# --- LLM provider API keys (optional: local CLIs can self-authenticate) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=
# xAI also accepts XAI_API_KEY as an alias for the Grok key.
XAI_API_KEY=

# --- Provider base URLs (override only for proxies / self-hosted gateways) ---
OPENAI_BASE_URL=
ANTHROPIC_BASE_URL=
GROK_BASE_URL=

# --- Inter-service auth (HMAC-SHA256 + JWT between orchestrator and skills) ---
# Must match on both the orchestrator and every skill server. Required in
# production; tests seed their own value.
SKILL_API_KEY=

# --- Git integration (used by ag_core/utils/git.py for push/auth) ---
GIT_USERNAME=
GIT_TOKEN=

# --- Optional paths / discovery ---
ANTIGRAVITY_BIN_PATH=
GENIUS_HUB_URL=
GENIUS_SERVICE_REGISTRY=
GENIUS_DB_PATH=
GENIUS_MEMORY_DB_PATH=
GENIUS_CHROMA_DIR=
CHROMA_PERSIST_DIR=

# --- Behaviour toggles (0/1) ---
# Re-enable the module-level API response cache (off under pytest).
ENABLE_GENIUS_CACHE=
# Toggle the TokenBucket rate limiter.
ENABLE_RATE_LIMITER=
# Keep the Codex CLI sandbox/approvals ON (1/true/yes). Default: bypassed.
GENIUS_CODEX_SANDBOX=

# --- Antigravity 2.0 (agy CLI, Gemini backend "agy") ---
# Explicit path to the agy executable. Default resolution: PATH, then
# %LOCALAPPDATA%\agy\bin\agy.exe. Auth is shared with the Antigravity IDE
# login (no API key needed).
GENIUS_AGY_PATH=
# agy runs with --sandbox (terminal restrictions) by default because print
# mode requires --dangerously-skip-permissions. Set 0 to drop --sandbox.
GENIUS_AGY_SANDBOX=

# --- Provider fallback chains (see ag_core/provider_factory.py) ---
# Auto mode: every role gets its default fallback chain (grok -> agy ->
# claude -> codex for research; codex/claude first elsewhere, agy last). A
# backend failing at runtime (e.g. grok 403 out-of-credits) falls through to
# the next one.
# GENIUS_PROVIDER_FALLBACK=1
# Explicit per-role chain (comma-separated backends: grok, agy, claude,
# codex). Example: run the research role on agy (Antigravity/Gemini), then
# claude - no grok at all.
# GENIUS_PROVIDER_GROK=agy,claude
