# Genius / Antigravity 2.0 — example environment file.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# ---------------------------------------------------------------------------
# Inter-service authentication (REQUIRED for distributed / skill-server mode)
# Shared secret used to sign JWTs (X-API-Key) and HMAC payload checksums
# between the orchestrator, central hub, skill servers and workers.
# Must be non-empty in production — distributed auth fails fast without it.
# ---------------------------------------------------------------------------
SKILL_API_KEY=change-me-to-a-long-random-secret

# ---------------------------------------------------------------------------
# LLM provider keys (optional — providers are local-CLI-first and fall back
# to these only if a CLI is unavailable / a provider needs an API key).
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=

# ---------------------------------------------------------------------------
# Storage paths (optional — sensible defaults are used if unset).
# ---------------------------------------------------------------------------
# SQLite database used for agent state / message bus.
GENIUS_DB_PATH=genius.db
# SQLite database used for the vector memory fallback store.
GENIUS_MEMORY_DB_PATH=genius_memory.db
# Where skill servers write their dynamic port registry.
# GENIUS_SERVICE_REGISTRY=.agents/service_registry.json

# ---------------------------------------------------------------------------
# Behaviour toggles (optional).
# ---------------------------------------------------------------------------
# Set to 1/true/yes to KEEP the Codex CLI sandbox & approval prompts ON.
# Unset (default) runs Codex with --dangerously-bypass-approvals-and-sandbox.
# GENIUS_CODEX_SANDBOX=
# Set to 1 to enforce the server-side rate limiter during pytest runs.
# ENABLE_RATE_LIMITER=

# ---------------------------------------------------------------------------
# Git integration (optional — only needed if agents push to a remote).
# ---------------------------------------------------------------------------
GIT_USERNAME=
GIT_TOKEN=
